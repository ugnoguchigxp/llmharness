{
	"runtime": "bun",
	"workspaceRoot": ".",
	"artifactsDir": "artifacts/runs",
	"adapters": {
		"localLlm": {
			"mode": "cli",
			"command": "/Users/y.noguchi/Code/localLlm/scripts/gemma4 --prompt {{prompt}}",
			"commandPromptMode": "arg",
			"commandPromptPlaceholder": "{{prompt}}",
			"model": "gemma4-default",
			"timeoutMs": 180000,
			"temperature": 0
		},
		"astmend": {
			"mode": "lib",
			"command": "astmend apply --json",
			"enableLibFallback": true,
			"libEntrypoint": "../Astmend/dist/index.js",
			"timeoutMs": 15000
		},
		"diffGuard": {
			"mode": "cli",
			"command": "diffguard --format json",
			"timeoutMs": 15000
		}
	},
	"judges": {
		"mode": "keyword",
		"confidenceThreshold": 0.5,
		"llm": {
			"apiPath": "/v1/chat/completions",
			"apiKeyEnv": "LOCAL_LLM_API_KEY",
			"model": "gemma4-default",
			"timeoutMs": 120000,
			"temperature": 0
		}
	},
	"context": {
		"enabled": true,
		"maxContextTokens": 4000,
		"includeImports": true,
		"includeTests": true,
		"maxFileLines": 500
	},
	"checks": {
		"runTypecheck": true,
		"typecheckCommand": "bun run typecheck",
		"runTests": true,
		"testCommand": "bun test"
	},
	"scoring": {
		"syntaxWeight": 30,
		"testWeight": 30,
		"riskWeight": 20,
		"minimalityWeight": 10,
		"instructionWeight": 10,
		"passThreshold": 80
	}
}
